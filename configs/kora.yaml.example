# Kora Configuration
# Copy this file to ~/.kora/config.yaml and customize as needed.

# Datasource configuration
# Enable or disable specific datasources and configure their options.
datasources:
  github:
    # Enable GitHub datasource (requires `gh` CLI to be installed and authenticated)
    enabled: true
    # Limit searches to specific organizations (empty = search all accessible repos)
    # orgs:
    #   - my-org
    #   - another-org

  slack:
    # Enable Slack datasource (requires token in keychain or KORA_SLACK_TOKEN env var)
    enabled: true
    # Limit to specific workspaces (empty = all workspaces)
    # workspaces:
    #   - my-workspace

# Digest configuration
# Controls how the digest is generated and displayed.
digest:
  # Default time window for fetching events
  # Accepts Go duration format: 16h, 30m, 24h, etc.
  window: 16h

  # Timezone for display
  # Use IANA zone names (e.g., "America/New_York", "Europe/London")
  # Use "Local" for system timezone
  timezone: Local

  # Default output format
  # Options: json, json-pretty, text
  format: text

# Security configuration
# Controls security-related behavior.
security:
  # Redact credentials in logs (recommended: true)
  redact_credentials: true

  # Per-datasource timeout
  # How long to wait for each datasource before timing out.
  # Accepts Go duration format: 30s, 1m, etc.
  datasource_timeout: 30s

  # Verify TLS certificates (recommended: true)
  # Only disable for testing with self-signed certificates.
  verify_tls: true
